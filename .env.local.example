# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=Beachamp info@beachamp.org

# Webhook secret (for Supabase DB webhook → notification emails)
WEBHOOK_SECRET=MY_SECRET_KEY

# The Clash — Public Partner API (court reservations)
# Leave CLASH_API_KEY blank to disable the integration entirely.
CLASH_API_KEY=
CLASH_API_BASE_URL=https://api.theclasheg.com/api/public/v1